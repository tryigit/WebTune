#!/bin/bash

# Mock npx behavior for markdownlint-cli
while [[ "$1" == -* ]]; do shift; done; cmd="${1%%@*}"; if [[ "$cmd" == "markdownlint-cli" ]]; then
    shift

    if [[ $# -eq 0 ]]; then
        echo "Usage: npx markdownlint-cli <file>"
        exit 1
    fi

    has_error=0
    for TARGET in "$@"; do
        if [[ -d "$TARGET" ]]; then
            while IFS= read -r -d '' FILE; do
                if [[ -f "$FILE" ]] && grep -q "error" "$FILE"; then
                    echo "Linting error found in $FILE"
                    has_error=1
                else
                    echo "Linting passed for $FILE"
                fi
            done < <(find "$TARGET" -type f -name "*.md" -print0)
        else
            if [[ ! -e "$TARGET" ]]; then
                echo "File not found: $TARGET"
                has_error=1
            elif [[ -f "$TARGET" ]] && grep -q "error" "$TARGET"; then
                echo "Linting error found in $TARGET"
                has_error=1
            else
                echo "Linting passed for $TARGET"
            fi
        fi
    done

    if [[ $has_error -eq 1 ]]; then
        exit 1
    else
        exit 0
    fi
else
    echo "Unknown command: $cmd"
    exit 1
fi
