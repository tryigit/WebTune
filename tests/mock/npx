#!/bin/bash

# Mock npx behavior for markdownlint-cli
while [[ "$1" == -* ]]; do shift; done; cmd="${1%%@*}"; if [[ "$cmd" == "markdownlint-cli" ]]; then
    shift

    if [[ $# -eq 0 ]]; then
        echo "Usage: npx markdownlint-cli <file>"
        exit 1
    fi

    has_error=0
    for FILE in "$@"; do
        if [[ ! -e "$FILE" ]]; then
            echo "File not found: $FILE"
            has_error=1
        elif [[ -d "$FILE" ]]; then
            dir_has_error=0
            while IFS= read -r -d '' MD_FILE; do
                if grep -q "error" "$MD_FILE"; then
                    echo "Linting error found in $MD_FILE"
                    has_error=1
                    dir_has_error=1
                else
                    echo "Linting passed for $MD_FILE"
                fi
            done < <(find "$FILE" -type f -name "*.md" -print0)
            if [[ $dir_has_error -eq 0 ]]; then
                echo "Linting passed for $FILE"
            fi
        elif [[ -f "$FILE" ]] && grep -q "error" "$FILE"; then
            echo "Linting error found in $FILE"
            has_error=1
        else
            echo "Linting passed for $FILE"
        fi
    done

    if [[ $has_error -eq 1 ]]; then
        exit 1
    else
        exit 0
    fi
else
    echo "Unknown command: $cmd"
    exit 1
fi
