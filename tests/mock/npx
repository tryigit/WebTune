#!/bin/bash

# Mock npx behavior for markdownlint-cli
while [[ "$1" == -* ]]; do shift; done; cmd="${1%%@*}"; if [[ "$cmd" == "markdownlint-cli" ]]; then
    shift

    if [[ $# -eq 0 ]]; then
        echo "Usage: npx markdownlint-cli <file>"
        exit 1
    fi

    has_error=0
    declare -A error_files=()

    existing_files=()
    for FILE in "$@"; do
        if [[ -f "$FILE" ]]; then
            existing_files+=("$FILE")
        fi
    done

    if [[ ${#existing_files[@]} -gt 0 ]]; then
        while IFS= read -r -d '' match; do
            error_files["$match"]=1
        done < <(grep -l -Z "error" "${existing_files[@]}" 2>/dev/null || true)
    fi

    for FILE in "$@"; do
        if [[ ! -e "$FILE" ]]; then
            echo "File not found: $FILE"
            has_error=1
        elif [[ ! -r "$FILE" ]]; then
            echo "Permission denied: $FILE"
            has_error=1
        elif [[ "${error_files["$FILE"]}" == "1" ]]; then
            echo "Linting error found in $FILE"
            has_error=1
        else
            echo "Linting passed for $FILE"
        fi
    done

    if [[ $has_error -eq 1 ]]; then
        exit 1
    else
        exit 0
    fi
else
    echo "Unknown command: $cmd"
    exit 1
fi
