#!/bin/bash

# Mock npx behavior for markdownlint-cli
if [[ "$1" == "markdownlint-cli" ]]; then
    shift

    if [[ $# -eq 0 ]]; then
        echo "Usage: npx markdownlint-cli <file>"
        exit 1
    fi

    has_error=0
    for FILE in "$@"; do
        if [[ -f "$FILE" && "$(<"$FILE")" == *error* ]]; then
            echo "Linting error found in $FILE"
            has_error=1
        else
            echo "Linting passed for $FILE"
        fi
    done

    if [[ $has_error -eq 1 ]]; then
        exit 1
    else
        exit 0
    fi
else
    echo "Unknown command: $1"
    exit 1
fi
